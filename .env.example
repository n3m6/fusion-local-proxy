# Environment variables for fusion-chat providers.
# Copy this file to `.env` and fill in real values for the providers you use.
# Local backends (Ollama, LM Studio) typically accept any non-empty dummy value.
#
# Each variable is referenced by an `apiKeyEnv` entry in fusion.config.json.

# OpenAI API key — used when a provider has apiKeyEnv: "OPENAI_API_KEY"
OPENAI_API_KEY=sk-your-key-here

# Anthropic API key — used when a provider has apiKeyEnv: "ANTHROPIC_API_KEY"
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Local Ollama "key" — used when a provider has apiKeyEnv: "OLLAMA_API_KEY"
# Ollama does not validate this; any non-empty value works.
OLLAMA_API_KEY=ollama

# OpenRouter API key — used when a provider has apiKeyEnv: "OPENROUTER_API_KEY"
OPENROUTER_API_KEY=sk-or-your-key-here

# DeepSeek API key — used when a provider has apiKeyEnv: "DEEPSEEK_API_KEY"
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Optional: HTTP server port (defaults to 3000 if unset)
# PORT=3000

# Optional: path to the config file (defaults to fusion.config.json)
# FUSION_CONFIG_PATH=fusion.config.json
