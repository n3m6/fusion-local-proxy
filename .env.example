# Environment variables for fusion-chat providers.
# Local backends (Ollama, LM Studio) typically accept a dummy value.

# OpenAI API key — used when fusion.config.json references apiKeyEnv: "OPENAI_API_KEY"
OPENAI_API_KEY=sk-your-key-here

# Anthropic API key — used when fusion.config.json references apiKeyEnv: "ANTHROPIC_API_KEY"
ANTHROPIC_API_KEY=sk-ant-your-key-here
